# =====================================================================
# FRONTEND (browser) — copy to .env.local and fill in real values.
# These ARE exposed to the browser. The anon key is meant to be public.
# =====================================================================
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Google OAuth (via Supabase) — no extra frontend env needed. Configure
# the Google provider in Supabase Studio → Auth → Providers → Google,
# and add http://localhost:3000/auth/callback (plus your prod URL) to:
#   * Supabase   → Auth → URL Configuration → Redirect URLs
#   * Google Cloud Console → APIs & Services → Credentials → OAuth client
#     "Authorized redirect URIs" should be:
#       https://YOUR-PROJECT-REF.supabase.co/auth/v1/callback
# See AUTH_SETUP.md for the full step-by-step.

# =====================================================================
# SUPABASE EDGE FUNCTION SECRETS — do NOT put these here.
# Set them with the supabase CLI so they never reach the browser:
#
#   supabase secrets set MISTRAL_API_KEY=sk-...
#   supabase secrets set APIFY_TOKEN=apify_api_...
#
# Optional override (defaults to mistral-large-latest):
#   supabase secrets set MISTRAL_MODEL=mistral-small-latest
# =====================================================================
